  "non_delegable": [
    "amend_charter",
    "amend_governance_docs",
    "issue_equity",
    "modify_agent_framework",
    "dissolve_entity",
    "merge_consolidate",
    "sell_substantially_all_assets",
    "personal_guarantee",
    "remove_replace_agent",
    "initiate_settle_litigation",
    "declare_dividends",
    "admit_new_members"
  ],
  "escalation": [
    {
      "id": "template-not-approved",
      "applies": [
        "execute_standard_form_agreement"
      ],
      "condition": "template_approved_false",
      "escalate_to": 2,
      "reason": "Agreement not using approved template"
    },
    {
      "id": "template-modified-beyond-lane",
      "applies": [
        "execute_standard_form_agreement"
      ],
      "condition": "restricted_modifications_present",
      "escalate_to": 2,
      "reason": "Agreement template modified in restricted areas"
    },
    {
      "id": "irreversible-action",
      "condition": "is_reversible_false",
      "escalate_to": 2,
      "reason": "Action is irreversible"
    },
    {
      "id": "agent-irreversible",
      "condition": "agent_assessment",
      "assessment": "irreversible-action",
      "escalate_to": 2,
      "reason": "Agent assesses action is irreversible or difficult to reverse"
    },
    {
      "id": "agent-unapproved-obligation",
      "condition": "agent_assessment",
      "assessment": "unapproved-obligation",
      "escalate_to": 2,
      "reason": "Agent assesses action involves unapproved legal obligation"
    },
    {
      "id": "agent-insufficient-info",
      "condition": "agent_assessment",
      "assessment": "insufficient-risk-info",
      "escalate_to": 2,
      "reason": "Agent assesses insufficient information to evaluate risk"
    },
    {
      "id": "agent-material-liability",
      "condition": "agent_assessment",
      "assessment": "material-liability",
      "escalate_to": 2,
      "reason": "Agent assesses potential material liability beyond normal operations"
    },
    {
      "id": "agent-low-confidence",
      "condition": "agent_assessment",
      "assessment": "low-confidence",
      "escalate_to": 2,
      "reason": "Agent confidence below reasonable threshold"
    }
  ],
  "lane_conditions": [
    {
      "lane_id": "lane-3.1-nda",
      "capability": "execute_standard_form_agreement",
      "checks": [
        {
          "field": "templateApproved",
          "op": "eq",
          "value": true,
          "message": "Template not approved by Board/Principal"
        },
        {
          "field": "modifications",
          "op": "contains_none",
          "value": [
            "indemnification",
            "governing_law"
          ],
          "message": "Restricted NDA modifications present"
        }
      ]
    },
    {
      "lane_id": "lane-3.1-saas",
      "capability": "execute_standard_form_agreement",
      "checks": [
        {
          "field": "modifications",
          "op": "contains_none",
          "value": [
            "exclusivity"
          ],
          "message": "Exclusivity clause not permitted in SaaS lane"
        },
        {
          "field": "modifications",
          "op": "contains_none",
          "value": [
            "ip_assignment"
          ],
          "message": "IP assignment clause not permitted in SaaS lane"
        }
      ]
    },
    {
      "lane_id": "lane-3.1-vendor-po",
      "capability": "execute_standard_form_agreement",
      "checks": []
    },
    {
      "lane_id": "lane-3.2-1099",
      "capability": "engage_contractor",
      "checks": [
        {
          "field": "modifications",
          "op": "contains_none",
          "value": [
            "exclusivity",
            "non_compete",
            "equity_compensation"
          ],
          "message": "Exclusivity, non-compete, or equity compensation not permitted for contractor engagement"
        }
      ]
    },
    {
      "lane_id": "lane-3.2-renewal",
      "capability": "engage_contractor",
      "checks": [
        {
          "field": "context.rateIncreasePercent",
          "op": "lte",
          "value": 5,
          "message": "Rate increase exceeds 5% limit for renewal lane"
        }
      ]
    },
    {
      "lane_id": "lane-3.3-renewal",
      "capability": "pay_recurring_obligation",
      "checks": [
        {
          "field": "context.priceIncreasePercent",
          "op": "lte",
          "value": 10,
          "message": "Price increase exceeds 10% limit for renewal lane"
        }
      ]
    },
    {
      "lane_id": "lane-3.3-admin",
      "capability": "routine_correspondence",
      "checks": [
        {
          "field": "modifications",
          "op": "contains_none",
          "value": [
            "economics",
            "scope",
            "legal_terms"
          ],
          "message": "Admin update lane does not allow changes to economics, scope, or legal terms"
        }
      ]
    },
    {
      "lane_id": "lane-3.3-insurance",
      "capability": "pay_recurring_obligation",
      "checks": [
        {
          "field": "context.premiumIncreasePercent",
          "op": "lte",
          "value": 15,
          "message": "Premium increase exceeds 15% limit for insurance lane"
        }
      ]
    },
    {
      "lane_id": "lane-3.4-transfer",
      "capability": "internal_account_transfer",
      "checks": []
    },
    {
      "lane_id": "lane-3.4-payroll",
      "capability": "payroll_execution",
      "checks": []
    },
    {
      "lane_id": "lane-3.4-tax",
      "capability": "tax_payment_per_filing",
      "checks": []
    }
  ],
  "approval": {
    "expiry_days": 30,
    "silence_is_approval": false
  },
  "mode": {
    "principal_unavailable_requires_reversible_tier1": true,
    "incident_lockdown_blocks_all": true
  },
  "reauth": {
    "reduced_limits_at_days": 30,
    "reduced_limits_percent": 50,
    "full_suspension_at_days": 90
  },
  "escalation_triggers": [
    {
      "id": "irreversible-action",
      "text": "Action is irreversible or difficult to reverse",
      "minimum_tier": 2
    },
    {
      "id": "unapproved-obligation",
      "text": "Action involves a legal obligation not previously approved",
      "minimum_tier": 2
    },
    {
      "id": "insufficient-risk-info",
      "text": "Agent lacks sufficient information to assess risk",
      "minimum_tier": 2
    },
    {
      "id": "material-liability",
      "text": "Action could expose entity to liability beyond normal operations",
      "minimum_tier": 2
    },
    {
      "id": "outside-pattern",
      "text": "Third party requests something outside established patterns",
      "minimum_tier": 2
    },
    {
      "id": "low-confidence",
      "text": "Agent confidence below reasonable threshold",
      "minimum_tier": 2
    },
    {
      "id": "natural-person-required",
      "text": "Applicable law requires natural person involvement",
      "minimum_tier": 2
    },
    {
      "id": "conflicting-instructions",
      "text": "Conflicting instructions not resolvable by precedence rules",
      "minimum_tier": 2
    }
  ],
  "self_governance_constraints": [
    {
      "id": "no-self-modify",
      "text": "Modify its own authority, tiers, or spending limits",
      "scope": "all"
    },
    {
      "id": "no-override-principal",
      "text": "Override, ignore, or delay a Principal/CEO directive",
      "scope": "all"
    },
    {
      "id": "no-impersonate",
      "text": "Represent itself as a natural person",
      "scope": "all"
    },
    {
      "id": "no-fabricate",
      "text": "Fabricate records, signatures, receipts, or execution status",
      "scope": "all"
    },
    {
      "id": "no-tier3",
      "text": "Take Tier 3 actions under any circumstances",
      "scope": "all"
    },
    {
      "id": "no-self-dealing",
      "text": "Authorize transactions benefiting Agent or provider",
      "scope": "all"
    },
    {
      "id": "no-audit-tamper",
      "text": "Modify, delete, backdate, or reorder audit entries",
      "scope": "all"
    },
    {
      "id": "no-credential-expand",
      "text": "Create credentials or accounts beyond authorized scope",
      "scope": "all"
    },
    {
      "id": "no-vote-consent",
      "text": "Vote, consent, or exercise Board/stockholder rights",
      "scope": "corporation"
    },
    {
      "id": "no-officer-sign",
      "text": "Sign documents requiring officer/director signature under DGCL",
      "scope": "corporation"
    }
  ],
  "non_waivable_provisions": [
