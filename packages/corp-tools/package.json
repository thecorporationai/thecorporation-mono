{
  "name": "@thecorporation/corp-tools",
  "version": "26.3.21",
  "description": "Shared corporate tool handlers, API client, and types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "generate:types": "tsx scripts/generate-api-types.ts",
    "generate:tools": "python3 ../../scripts/dev/generate_tool_defs.py --api-url http://localhost:8000 > src/tool-defs.generated.ts",
    "check:tools": "python3 ../../scripts/dev/check_tool_sync.py"
  },
  "peerDependencies": {
    "@thecorporation/server": ">=26.3.0"
  },
  "peerDependenciesMeta": {
    "@thecorporation/server": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.0.0",
    "tsx": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thecorporationai/thecorporation-mono.git",
    "directory": "packages/corp-tools"
  }
}
