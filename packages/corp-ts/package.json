{
  "name": "@thecorporation/corp",
  "version": "0.1.0",
  "description": "TypeScript client and binary wrapper for TheCorporation corporate governance platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/thecorporationai/thecorporation-mono",
    "directory": "packages/corp-ts"
  },
  "homepage": "https://github.com/thecorporationai/thecorporation-mono#readme",
  "bugs": {
    "url": "https://github.com/thecorporationai/thecorporation-mono/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    }
  },
  "bin": {
    "corp": "./dist/bin.js"
  },
  "files": [
    "dist/",
    "install.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "postinstall": "node install.js"
  },
  "optionalDependencies": {
    "@thecorporation/corp-darwin-arm64": "0.1.0",
    "@thecorporation/corp-darwin-x64": "0.1.0",
    "@thecorporation/corp-linux-arm64-gnu": "0.1.0",
    "@thecorporation/corp-linux-x64-gnu": "0.1.0",
    "@thecorporation/corp-win32-x64-msvc": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
