FROM node:22-slim AS pi

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    bash \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Pi and keep a local copy of the Corp extension for the entrypoint.
COPY packages/agent/ /opt/corp-extension/
RUN npm install -g @mariozechner/pi-coding-agent /opt/corp-extension

COPY services/agent-worker/runtime/pi-entrypoint.mjs /app/pi-entrypoint.mjs

RUN useradd -u 65534 -r -s /bin/false -o agent \
    && mkdir -p /workspace /tmp \
    && chown 65534:65534 /workspace /tmp

USER 65534

CMD ["node", "/app/pi-entrypoint.mjs"]
